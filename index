<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anton Magomedow - Extreme Networks</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 10px;
        }

        .card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 500px;
            width: 100%;
            overflow: hidden;
            animation: slideIn 0.6s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header {
            background: linear-gradient(135deg, #6B21A8 0%, #4C1D95 100%);
            padding: 25px 20px;
            color: white;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
            pointer-events: none;
        }

        .name {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 6px;
            position: relative;
            z-index: 1;
        }

        .title {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 3px;
            color: rgba(255, 255, 255, 0.95);
            position: relative;
            z-index: 1;
        }

        .company {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.8);
            position: relative;
            z-index: 1;
        }

        .divider {
            height: 1px;
            background: rgba(107, 33, 168, 0.2);
            margin: 15px 0;
        }

        .content {
            padding: 20px;
        }

        .region {
            text-align: center;
            margin-bottom: 15px;
            font-size: 13px;
            color: #1a1a2e;
            font-weight: 500;
        }

        .contact-row {
            display: flex;
            gap: 10px;
            margin-bottom: 12px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            color: #6B21A8;
            font-size: 12px;
            font-weight: 600;
            transition: color 0.3s;
            padding: 6px 10px;
            background: #f0e6ff;
            border-radius: 6px;
        }

        .contact-item:hover {
            background: #e8d4ff;
            color: #4C1D95;
        }

        .contact-icon {
            font-size: 14px;
        }

        .button-row {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
            flex-direction: column;
        }

        .download-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            background: linear-gradient(135deg, #6B21A8 0%, #4C1D95 100%);
            color: white;
            padding: 10px 16px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            width: 100%;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .download-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(107, 33, 168, 0.3);
        }

        .qr-section {
            text-align: center;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid #e0e0e0;
        }

        .qr-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6B21A8;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .qr-section img {
            width: 120px;
            height: 120px;
            border-radius: 6px;
        }

        .footer {
            background: #f8f8f8;
            padding: 12px 20px;
            text-align: center;
            border-top: 1px solid #e0e0e0;
            font-size: 10px;
            color: #999;
        }

        @media (max-width: 480px) {
            body {
                padding: 5px;
            }

            .header {
                padding: 20px 15px;
            }

            .name {
                font-size: 22px;
            }

            .content {
                padding: 15px;
            }

            .contact-item {
                font-size: 11px;
                padding: 5px 8px;
            }

            .qr-section img {
                width: 100px;
                height: 100px;
            }
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="header">
            <div class="name">Anton Magomedow</div>
            <div class="title">Account Executive</div>
            <div class="company">Extreme Networks</div>
        </div>

        <div class="content">
            <div class="region">
                📍 Sachsen · Sachsen-Anhalt · Thüringen
            </div>

            <div class="divider"></div>

            <div class="contact-row">
                <a href="tel:+496947860103" class="contact-item">
                    <span class="contact-icon">📞</span>
                    <span>+49 69 47860103</span>
                </a>
                <a href="tel:+491511504478" class="contact-item">
                    <span class="contact-icon">📱</span>
                    <span>+49 151 15044785</span>
                </a>
            </div>

            <div class="contact-row">
                <a href="mailto:amagomedow@extremenetworks.com" class="contact-item">
                    <span class="contact-icon">✉</span>
                    <span>E-Mail</span>
                </a>
                <a href="https://www.linkedin.com/in/anton-magomedow/" target="_blank" class="contact-item">
                    <span class="contact-icon">in</span>
                    <span>LinkedIn</span>
                </a>
            </div>

            <div class="button-row">
                <a href="kontakt.vcf" download class="download-link">📇 Kontakt speichern</a>
            </div>

            <div class="qr-section">
                <div class="qr-label">QR Code</div>
                <img src="qr-code.png" alt="QR Code">
            </div>
        </div>

        <div class="footer">
            © 2026 Extreme Networks
        </div>
    </div>

</body>
</html>
